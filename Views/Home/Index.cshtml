@{
    ViewData["Title"] = "ExpenseManager - Smart Expense Tracking";
}

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-blue-100 flex items-center">
    <div class="container mx-auto px-6 py-16">
        <!-- Hero Section -->
        <div class="text-center mb-20">
            <h1 class="text-5xl font-extrabold text-blue-700 mb-4 drop-shadow-md">
                ExpenseManager
            </h1>
            <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
                Track your expenses, manage budgets, and gain control of your finances with ease.
            </p>
        </div>

        <!-- Features Section -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            <div class="bg-white rounded-2xl shadow-lg p-8 text-center hover:shadow-2xl transition">
                <div class="text-blue-600 text-7xl mb-2">💳</div>
                <h3 class="text-xl font-semibold mb-2">Track Expenses</h3>
                <p class="text-gray-500">Record your daily expenses quickly and categorize them with ease.</p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-8 text-center hover:shadow-2xl transition">
                <div class="text-green-600 text-7xl mb-2">📊</div>
                <h3 class="text-xl font-semibold mb-2">Analyze Spending</h3>
                <p class="text-gray-500">Get insights and reports on where your money goes every month.</p>
            </div>

            <div class="bg-white rounded-2xl shadow-lg p-8 text-center hover:shadow-2xl transition">
                <div class="text-yellow-500 text-7xl mb-2">📂</div>
                <h3 class="text-xl font-semibold mb-2">Manage Categories</h3>
                <p class="text-gray-500">Organize expenses into categories to simplify budget planning.</p>
            </div>

        </div>

        <!-- Call to Action -->
        <div class="text-center mt-20">
            <h4 class="text-2xl font-bold text-gray-800 mb-6">
                Ready to take control of your finances?
            </h4>
        </div>
    </div>
</div>
