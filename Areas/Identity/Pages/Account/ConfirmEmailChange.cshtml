@page
@model ConfirmEmailChangeModel
@{
    ViewData["Title"] = "Confirm email change";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 rounded-4 text-center" style="max-width: 500px; width: 100%;">
        <div class="card-body p-5">

            <!-- Title -->
            <h1 class="mb-3">@ViewData["Title"]</h1>

            <!-- Status Message -->
            <p class="text-muted fs-5">
                <partial name="_StatusMessage" model="Model.StatusMessage" />
            </p>

            <!-- Action Button -->
            @if (!string.IsNullOrEmpty(Model.StatusMessage) && Model.StatusMessage.Contains("Thank you"))
            {
                <a asp-page="/Index" class="btn btn-success mt-4 rounded-3 shadow-sm px-4">
                    Go to Dashboard
                </a>
            }
            else if (!string.IsNullOrEmpty(Model.StatusMessage) && Model.StatusMessage.Contains("Error"))
            {
                <a asp-page="/Account/Manage/Email" class="btn btn-danger mt-4 rounded-3 shadow-sm px-4">
                    Try Again
                </a>
            }
        </div>
    </div>
</div>
