@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 rounded-4" style="max-width: 500px; width: 100%;">
        <div class="card-body p-5">
            <h1 class="text-center mb-3">@ViewData["Title"]</h1>
            <h5 class="text-muted text-center mb-4">Create a new password for your account</h5>
            <hr />

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                @* Hidden fields for token and email *@
                <input asp-for="Input.Code" type="hidden" />
                <input asp-for="Input.Email" type="hidden" />

                <div class="form-floating mb-4">
                    <input asp-for="Input.Password" type="password" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="Enter new password" />
                    <label asp-for="Input.Password" class="form-label"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="Confirm new password" />
                    <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="w-100 btn btn-lg btn-primary rounded-3 shadow-sm">
                    🔑 Reset Password
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
