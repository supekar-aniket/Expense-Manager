@page
@model ExpenseManager.Areas.Identity.Pages.Account.ResetPasswordTokenExpiredModel
@{
    ViewData["Title"] = "Reset Link Expired";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 rounded-4 text-center" style="max-width: 500px; width: 100%;">
        <div class="card-body p-5">
            <h1 class="text-danger mb-3">⚠️ Link Expired</h1>
            <h5 class="text-muted mb-4">
                This password reset link has expired.
                For security reasons, reset links are only valid for <strong>10 minutes</strong>.
            </h5>
            <hr />
            <a asp-page="./ForgotPassword" class="btn btn-lg btn-primary rounded-3 shadow-sm">
                🔄 Request New Link
            </a>
        </div>
    </div>
</div>
