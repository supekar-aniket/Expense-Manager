@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="d-flex justify-content-center mt-0 mb-5">

    <div class="card shadow-sm border-0 rounded-3" style="max-width: 500px; width: 100%;">
        <div class="card-body p-4">
            <h3 class="text-center mb-3">@ViewData["Title"]</h3>

            <p class="text-muted small text-center">
                Your account contains personal data that you have given us.<br />
                This page allows you to <strong>download</strong> or <strong>delete</strong> that data.
            </p>

            <p class="text-danger fw-semibold small text-center mb-4">
                Deleting this data will permanently remove your account.<br />
                This action <u>cannot</u> be undone.
            </p>

            <form id="download-data" asp-page="DownloadPersonalData" method="post" class="d-grid mb-3">
                <button class="btn btn-primary rounded-2 shadow-sm" type="submit">
                    ⬇️ Download My Data
                </button>
            </form>

            <div class="d-grid">
                <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger rounded-2 shadow-sm">
                    ❌ Delete My Account
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
