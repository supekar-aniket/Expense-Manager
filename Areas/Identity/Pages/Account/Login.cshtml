@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<h1>@ViewData["Title"]</h1>
<div class="row">
    <div class="col-md-4">
        <section>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div> 
                <div class="mt-3 text-center">
                    <p>
                        <a asp-page="./ForgotPassword" asp-route-returnUrl="@Model.ReturnUrl">Forgot your password?</a>
                    </p>
                </div>
                <div class="mt-3 text-center">
                    <p>
                        Don’t have an account?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register here</a>
                    </p>
                </div>
            </form>
        </section>
    </div>

    <div class="col-md-6 d-flex align-items-center justify-content-center">
        <section class="p-4">
            <div>
                <h1 class="text-4xl text-center font-bold mb-4">Welcome to ExpenseManager</h1>
                <p class="text-lg leading-relaxed mb-6">
                    Take control of your finances with <strong>ExpenseManager</strong>.
                    Easily track your daily expenses, analyze spending, and gain insights into your financial habits.
                    Your data is secure, private, and accessible only by you.
                </p>
                <ul class="list-unstyled space-y-3 text-lg">
                    <li>✅ Track expenses by category</li>
                    <li>✅ Export and manage your data</li>
                    <li>✅ Secure authentication with Identity</li>
                </ul>
            </div>
        </section>
    </div>
    
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
